;cyclic SKILL for schematic editor
schSetCmdOption( schStretchForm 'snapMode list( "anyAngle" "orthogonal" ) 2 "toggle snapMode" )
schSetCmdOption( schMoveForm 'snapMode list( "anyAngle" "orthogonal" ) 2 "toggle snapMode" )
schSetCmdOption( schCopyForm 'snapMode list( "anyAngle" "orthogonal" ) 2 "toggle snapMode" )
schSetCmdOption( schCreateNoteShapeForm 'shape list("line" "rectangle" "polygon") 2 "toggle noteShape" )

schSetCmdOption(schSymStretchForm 'snapMode list("anyAngle" "orthogonal") 2 "toggle snapMode")

